{
  "uid": "mcp-isolation-proof",
  "title": "Two-Tenant AWS-MCP Isolation Proof",
  "tags": ["mcp", "isolation", "004"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "org",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(mcp_requests_total, org)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Per-tenant traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests/sec by tenant",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "HTTP request rate to /mcp, broken down per tenant (org derived from Host).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org) (rate(mcp_requests_total{org=~\"$org\", org!=\"\"}[1m]))", "legendFormat": "{{org}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests/sec by tenant & status code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Status codes per tenant. 401 = rejected (cross-tenant/invalid token); 200/202 = served.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org, code) (rate(mcp_requests_total{org=~\"$org\", org!=\"\"}[1m]))", "legendFormat": "{{org}} · {{code}}" }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Isolation signals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cross-tenant rejections — HTTP 401/sec by tenant",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "A spike here during the adversarial suite is the gateway rejecting a foreign tenant's token (audience/issuer mismatch) — fail-closed isolation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 60 }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org) (rate(mcp_requests_total{code=\"401\", org=~\"$org\", org!=\"\"}[1m]))", "legendFormat": "{{org}} rejected" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tool calls/sec by tenant & outcome",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "MCP tools/call dispatch rate per tenant. outcome=error includes quota (rate-limit) responses.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org, outcome) (rate(mcp_tool_calls_total{org=~\"$org\", org!=\"\"}[1m]))", "legendFormat": "{{org}} · {{outcome}}" }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Tool usage & totals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tool calls/sec by tenant & tool",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Which AWS MCP tool each tenant exercises (e.g. aws__call_aws).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org, tool) (rate(mcp_tool_calls_total{org=~\"$org\", org!=\"\"}[1m]))", "legendFormat": "{{org}} · {{tool}}" }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Total tool calls by tenant",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org) (mcp_tool_calls_total{org=~\"$org\", org!=\"\"})", "legendFormat": "{{org}}" }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Tool-call errors by tenant",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cumulative error-outcome tool calls per tenant (incl. cross-bucket denials + quota).",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (org) (mcp_tool_calls_total{outcome=\"error\", org=~\"$org\", org!=\"\"})", "legendFormat": "{{org}}" }
      ]
    }
  ]
}
