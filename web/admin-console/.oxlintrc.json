{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/cloud-console/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Sans Condensed|IBM Plex Mono|IBM Plex Serif))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Sans Condensed, IBM Plex Mono, IBM Plex Serif."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|kind|size|disabled|iconOnly|renderIcon|href|onClick|type|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, kind, size, disabled, iconOnly, renderIcon, href, onClick, type, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:primary|secondary|tertiary|ghost|danger|danger-tertiary)$/]",
        "message": "<Button> kind must be one of 'primary' | 'secondary' | 'tertiary' | 'ghost' | 'danger' | 'danger-tertiary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|disabled|onChange|id|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, disabled, onChange, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='InlineNotification'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|subtitle|onClose|hideClose|className|key|ref|className|style|children)$/]",
        "message": "<InlineNotification> doesn't accept that prop. Declared props: kind, title, subtitle, onClose, hideClose, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='InlineNotification'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:error|success|warning|info)$/]",
        "message": "<InlineNotification> kind must be one of 'error' | 'success' | 'warning' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|max|helperText|status|hideLabel|indeterminate|className|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: label, value, max, helperText, status, hideLabel, indeterminate, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:active|success|error)$/]",
        "message": "<ProgressBar> status must be one of 'active' | 'success' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Search'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|defaultValue|size|onChange|onClear|className|key|ref|className|style|children)$/]",
        "message": "<Search> doesn't accept that prop. Declared props: placeholder, value, defaultValue, size, onChange, onClear, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Search'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Search> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|value|defaultValue|size|disabled|onChange|id|className|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, children, value, defaultValue, size, disabled, onChange, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Select> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|selectedIndex|defaultIndex|onChange|children|className|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, selectedIndex, defaultIndex, onChange, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|type|size|filter|renderIcon|onClose|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, type, size, filter, renderIcon, onClose, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:gray|cool-gray|blue|green|red|purple|teal|magenta|cyan|outline)$/]",
        "message": "<Tag> type must be one of 'gray' | 'cool-gray' | 'blue' | 'green' | 'red' | 'purple' | 'teal' | 'magenta' | 'cyan' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|value|defaultValue|placeholder|type|size|helperText|invalid|invalidText|disabled|onChange|className|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: label, id, value, defaultValue, placeholder, type, size, helperText, invalid, invalidText, disabled, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<TextInput> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|selected|href|onClick|className|key|ref|className|style|children)$/]",
        "message": "<Tile> doesn't accept that prop. Declared props: children, variant, selected, href, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:base|clickable|selectable)$/]",
        "message": "<Tile> variant must be one of 'base' | 'clickable' | 'selectable'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|size|labelOn|labelOff|hideStateLabel|disabled|onChange|id|className|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: label, checked, defaultChecked, size, labelOn, labelOff, hideStateLabel, disabled, onChange, id, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Toggle> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
