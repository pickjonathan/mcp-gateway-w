{
  "name": "mcp-admin-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Admin console UI (Carbon Design System) for the multi-tenant MCP runtime",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "oxlint -c .oxlintrc.json --ignore-pattern 'src/design-system/shell/**' src"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "oidc-client-ts": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "msw": "^2.4.9",
    "oxlint": "^0.9.10",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3"
  }
}
